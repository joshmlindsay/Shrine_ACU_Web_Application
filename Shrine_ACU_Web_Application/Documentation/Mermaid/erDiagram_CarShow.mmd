erDiagram
    CAR_SHOWS ||--o{ CAR_SHOW_SCORING_QUESTIONS : "defines"
    CAR_SHOWS ||--o{ CAR_SHOW_ENTRIES : "includes"
    CAR_SHOW_SCORING_QUESTIONS ||--o{ CAR_SHOW_ANSWERS : "answered by"
    CAR_SHOW_ENTRIES }o--|| CAR_DETAILS : "participates in"
    CAR_SHOW_ENTRIES ||--o{ CAR_SHOW_ANSWERS : "receives"
    CAR_SHOW_ANSWERS }o--|| CAR_SHOW_SCORING_QUESTIONS : "answers"
    CAR_SHOWS ||--o{ CAR_SHOW_CLASS : "has"
    CAR_SHOW_ENTRIES }o--|| CAR_SHOW_CLASS : "assigned to"
    CLASS_TYPE ||--o{ CAR_SHOW_CLASS : "defines"
    CLASS_TYPE ||--o{ CLASS_OPTION : "contains"
    CAR_SHOW_CLASS }o--o{ CLASS_OPTION : "may use"
    
    CAR_DETAILS {
        string vin PK "Vehicle Identification Number"
        string make "Brand/Manufacturer"
        string model "Model name"
        int year "Year of manufacture"
        string color "Exterior color"
        string bodyType "Sedan, SUV, Coupe, etc."
        string fuelType "Gasoline, Diesel, Electric, etc."
        string transmission "Manual or Automatic"
        int mileage "Odometer reading in miles"
        string licensePlate "Registration plate"
        string engineSize "Engine displacement in liters"
        int horsepower "Engine power output"
        string exterior "Exterior condition"
        string interior "Interior material/condition"
        string status "Active, Sold, In Repair, etc."
        decimal price "Current market value"
        date purchaseDate "Date of acquisition"
        string owner "Owner name/ID"
        string serviceHistory "Maintenance records"
        boolean insured "Insurance status"
        string paintCode "Original/current paint specifications"
        boolean originalPaint "Factory original paint indicator"
        string restorationStatus "Original, Restored, Modified, Partial"
        int restorationYear "Year restoration was completed"
        string originality "Stock, Light Mods, Modified, Custom"
        string provenance "Historical ownership/documentation"
        boolean documentedHistory "Complete records available"
        int showAppearances "Number of shows participated in"
        string showAwards "Awards won at shows"
        string judgeRatings "Scoring from concours judges"
        string rarity "Common, Uncommon, Rare, Very Rare"
        string historicalSignificance "Notable facts/historical importance"
        string specialFeatures "Unique modifications or features"
        decimal estimatedShowValue "Estimated value for show purposes"
        int concourScore "Out of 100 rating"
        string mechanicalCondition "Running, Restoration Needed, etc."
        boolean originalEngine "Original engine or replacement"
        boolean originalTransmission "Original transmission or replacement"
        string authenticity "Documentation level: Certified, Verified, Claimed"
    }

    CAR_SHOWS {
        int showId PK "Unique car show identifier"
        string name "Official show name"
        string location "City, venue, address"
        date eventDate "Start date of show"
        date endDate "End date of show"
        string category "Antique, Classic, Hot Rod, etc."
        string judgeType "Professional, Amateur, Peer, etc."
        int totalParticipants "Expected or actual participant count"
        string scoringFormat "Concours, Popular Vote, Tiered, etc."
        string description "Show details/notes"
        boolean active "Currently accepting entries"
        timestamp createdDate "When record was created"
        string createdBy "User/admin who created show"
    }

    CAR_SHOW_ENTRIES {
        int entryId PK "Unique entry identifier"
        int showId FK "Reference to CAR_SHOWS"
        string vin FK "Reference to CAR_DETAILS"
        int classId FK "Reference to CAR_SHOW_CLASS"
        int entryNumber "Official entry number for show"
        date registrationDate "When car was registered"
        string category "Placeholder"
        string status "Registered, Judged, Withdrawn, etc."
        decimal judgeScore "Final aggregate score"
        string placement "1st Place, Runner-up, etc."
        string notes "Entry-specific notes"
    }

    CAR_SHOW_SCORING_QUESTIONS {
        int questionId PK "Unique question identifier"
        int showId FK "Reference to CAR_SHOWS"
        string questionText "The actual question/criterion"
        string answerType "NUMERIC, BOOLEAN, TEXT"
        int sortOrder "Display/judging order"
        int maxScore "Maximum numeric value if applicable"
        int minScore "Minimum numeric value if applicable"
        string category "Category this question belongs to"
        string description "Guidance for judges"
        boolean required "Must be answered"
        boolean active "Question is in use"
        string judgeNotes "Internal notes for judges"
        timestamp createdDate "When question was created"
    }

    CAR_SHOW_ANSWERS {
        int answerId PK "Unique answer record identifier"
        int questionId FK "Reference to SCORING_QUESTIONS"
        int entryId FK "Reference to CAR_SHOW_ENTRIES"
        decimal numericAnswer "Answer if type is NUMERIC"
        boolean booleanAnswer "Answer if type is BOOLEAN"
        string textAnswer "Answer if type is TEXT"
        string comments "Judge comments/notes"
        string judgedBy "Judge name/ID"
        timestamp answeredDate "When answer was recorded"
        timestamp lastModified "Last update timestamp"
    }    

    CLASS_TYPE {
        int typeId PK "Unique class type identifier"
        string typeName "Name of classification type"
        string description "Description of this type (e.g., Antique, Classic, Muscle)"
        string classificationMethod "How defined: PREDEFINED, BRAND, NATIONALITY, YEAR_RANGE, CUSTOM"
        boolean allowMultiple "Can a car belong to multiple classes of this type"
        int displayOrder "Display order in UI"
        boolean active "Is this type currently in use"
    }

    CLASS_OPTION {
        int optionId PK "Unique class option identifier"
        int typeId FK "Reference to CLASS_TYPE"
        string optionValue "The actual value (e.g., Jeep, British, 1960-1980)"
        string description "Description of this option"
        int startYear "For year-based classifications"
        int endYear "For year-based classifications"
        string category "Sub-category if needed"
        boolean active "Is this option available"
    }

    CAR_SHOW_CLASS {
        int classId PK "Unique class identifier"
        int showId FK "Reference to CAR_SHOWS"
        int typeId FK "Reference to CLASS_TYPE"
        string className "The actual class name as shown in show"
        string description "Class description/rules"
        int optionId FK "Reference to CLASS_OPTION"
        int minYear "Minimum year for Antique/year-based classes"
        int maxYear "Maximum year for Antique/year-based classes"
        string customCriteria "Custom criteria if not standard"
        int expectedEntries "Estimated number of entries"
        int displayOrder "Display order in show"
        boolean active "Class is active in this show"
    }