@page "/fetch-reset-password"
@rendermode InteractiveServer
@inject AcuCarShowClient Client
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Reset Password</PageTitle>

<RadzenRow JustifyContent="JustifyContent.Center" class="mt-5">
    <RadzenColumn Size="12" SizeMD="6" SizeLG="5">
        <RadzenCard>
            <RadzenStack Gap="1rem">
                <RadzenText TextStyle="TextStyle.H4">Reset Password</RadzenText>

                @if (resetComplete)
                {
                    <RadzenAlert AlertStyle="AlertStyle.Success" AllowClose="false">
                        Your password has been reset successfully.
                    </RadzenAlert>
                    <RadzenRow JustifyContent="JustifyContent.Center">
                        <RadzenText TextStyle="TextStyle.Body2">
                            You can now <RadzenLink Path="/fetch-login" Text="sign in" /> with your new password.
                        </RadzenText>
                    </RadzenRow>
                }
                else if (isInvalidLink)
                {
                    <RadzenAlert AlertStyle="AlertStyle.Danger" AllowClose="false">
                        @invalidLinkMessage
                    </RadzenAlert>
                    <RadzenRow JustifyContent="JustifyContent.Center">
                        <RadzenText TextStyle="TextStyle.Body2">
                            <RadzenLink Path="/fetch-forgot-password" Text="Request a new reset link" />
                        </RadzenText>
                    </RadzenRow>
                }
                else
                {
                    @if (!string.IsNullOrWhiteSpace(errorMessage))
                    {
                        <RadzenAlert AlertStyle="AlertStyle.Danger">@errorMessage</RadzenAlert>
                    }

                    <RadzenText TextStyle="TextStyle.Body2">Enter your new password below.</RadzenText>

                    <RadzenTemplateForm TItem="ResetPasswordModel" Data="@form" Submit="HandleSubmitAsync">
                        <RadzenStack Gap="0.75rem">
                            <RadzenFormField Text="New Password" Variant="Variant.Outlined" Style="width:100%;">
                                <RadzenPassword Name="Password" Value="@form.Password" Change="OnPasswordChange" @oninput="OnPasswordInput" Style="width:100%;" />
                            </RadzenFormField>
                            <RadzenRequiredValidator Component="Password" Text="Password is required" Popup="true" />

                            @if (!string.IsNullOrEmpty(form.Password))
                            {
                                <RadzenStack Gap="0.25rem">
                                    <RadzenProgressBar Value="@passwordStrengthPercent" ShowValue="false" ProgressBarStyle="@passwordBarStyle" Style="height:6px;border-radius:3px;" />
                                    <RadzenText TextStyle="TextStyle.Caption" Style="@passwordLabelStyle">Strength: @passwordStrengthLabel</RadzenText>
                                    <RadzenStack Gap="0.1rem">
                                        @foreach (var rule in passwordRules)
                                        {
                                            <RadzenText TextStyle="TextStyle.Caption" Style="@(rule.Met ? "color:var(--app-input-valid);" : "color:var(--app-text);opacity:0.55;")">
                                                @(rule.Met ? "✓" : "○") @rule.Text
                                            </RadzenText>
                                        }
                                    </RadzenStack>
                                </RadzenStack>
                            }

                            <RadzenFormField Text="Confirm Password" Variant="Variant.Outlined" Style="width:100%;">
                                <RadzenPassword Name="ConfirmPassword" @bind-Value="form.ConfirmPassword" @oninput="OnConfirmPasswordInput" Style="width:100%;" />
                            </RadzenFormField>
                            <RadzenRequiredValidator Component="ConfirmPassword" Text="Please confirm your password" Popup="true" />
                            @if (confirmMismatch)
                            {
                                <RadzenText TextStyle="TextStyle.Caption" Style="color:#e50000;">Passwords do not match</RadzenText>
                            }

                            <RadzenButton Text="Reset Password"
                                          ButtonType="ButtonType.Submit"
                                          ButtonStyle="ButtonStyle.Primary"
                                          Icon="lock_reset"
                                          Disabled="isBusy"
                                          Style="width:100%;margin-top:0.5rem;" />
                        </RadzenStack>
                    </RadzenTemplateForm>
                }
            </RadzenStack>
        </RadzenCard>
    </RadzenColumn>
</RadzenRow>

@code {
    [SupplyParameterFromQuery(Name = "username")]
    public string? Username { get; set; }

    [SupplyParameterFromQuery(Name = "token")]
    public string? Token { get; set; }

    private ResetPasswordModel form = new();
    private bool isBusy;
    private bool resetComplete;
    private bool isInvalidLink;
    private string invalidLinkMessage = "This password reset link is invalid or has expired.";
    private string? errorMessage;
    private bool confirmMismatch;

    private double passwordStrengthPercent;
    private string passwordStrengthLabel = "";
    private string passwordLabelStyle = "";
    private ProgressBarStyle passwordBarStyle = ProgressBarStyle.Danger;
    private List<PasswordRule> passwordRules = [];

    protected override void OnParametersSet()
    {
        if (string.IsNullOrWhiteSpace(Username) || string.IsNullOrWhiteSpace(Token))
        {
            isInvalidLink = true;
            invalidLinkMessage = "This password reset link is missing required information.";
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || isInvalidLink) return;

        // Remove token from URL bar after capturing query params — token should not persist in browser history
        await JS.InvokeVoidAsync("window.history.replaceState", null, string.Empty, "/fetch-reset-password");
    }

    private void OnPasswordInput(ChangeEventArgs e)
    {
        form.Password = e.Value?.ToString();
        EvaluatePasswordStrength(form.Password);
        confirmMismatch = !string.IsNullOrEmpty(form.ConfirmPassword) &&
                          !string.Equals(form.Password, form.ConfirmPassword, StringComparison.Ordinal);
    }

    private void OnConfirmPasswordInput(ChangeEventArgs e)
    {
        form.ConfirmPassword = e.Value?.ToString();
        confirmMismatch = !string.IsNullOrEmpty(form.ConfirmPassword) &&
                          !string.Equals(form.Password, form.ConfirmPassword, StringComparison.Ordinal);
    }

    private void OnPasswordChange(object? value)
    {
        form.Password = value?.ToString();
        EvaluatePasswordStrength(form.Password);
    }

    private async Task HandleSubmitAsync(ResetPasswordModel _)
    {
        errorMessage = null;

        if (passwordRules.Count == 0 || passwordRules.Any(r => !r.Met))
        {
            errorMessage = "Password does not meet all requirements.";
            return;
        }

        if (!string.Equals(form.Password, form.ConfirmPassword, StringComparison.Ordinal))
        {
            errorMessage = "Passwords do not match.";
            return;
        }

        isBusy = true;
        try
        {
            await Client.Api.AppUsers.ResetPassword.PostAsync(new PasswordResetCompleteDto
            {
                Username = Username,
                ResetToken = Token,
                NewPassword = form.Password
            });

            resetComplete = true;
        }
        catch (Exception ex)
        {
            var msg = ex.Message;
            if (msg.Contains("expired", StringComparison.OrdinalIgnoreCase))
            {
                isInvalidLink = true;
                invalidLinkMessage = "This reset link has expired. Please request a new one.";
            }
            else if (msg.Contains("400") || msg.Contains("401") || msg.Contains("404") ||
                     msg.Contains("invalid", StringComparison.OrdinalIgnoreCase) ||
                     msg.Contains("not requested", StringComparison.OrdinalIgnoreCase) ||
                     msg.Contains("not found", StringComparison.OrdinalIgnoreCase))
            {
                isInvalidLink = true;
                invalidLinkMessage = "This reset link is invalid. Please request a new one.";
            }
            else
            {
                errorMessage = "Unable to reset password. Please try again or request a new reset link.";
            }
        }
        finally
        {
            isBusy = false;
        }
    }

    private void EvaluatePasswordStrength(string? password)
    {
        if (string.IsNullOrEmpty(password))
        {
            passwordRules = [];
            passwordStrengthPercent = 0;
            passwordStrengthLabel = "";
            return;
        }

        passwordRules =
        [
            new("At least 8 characters", password.Length >= 8),
            new("Uppercase letter (A–Z)", password.Any(char.IsUpper)),
            new("Lowercase letter (a–z)", password.Any(char.IsLower)),
            new("Number (0–9)", password.Any(char.IsDigit)),
            new("Special character (!@#$%...)", password.Any(c => !char.IsLetterOrDigit(c)))
        ];

        var metCount = passwordRules.Count(r => r.Met);
        (passwordStrengthPercent, passwordStrengthLabel, passwordBarStyle, passwordLabelStyle) = metCount switch
        {
            0 or 1 => (20d,  "Weak",     ProgressBarStyle.Danger,  "color:#e50000;"),
            2      => (40d,  "Fair",     ProgressBarStyle.Warning, "color:#e07000;"),
            3      => (60d,  "Moderate", ProgressBarStyle.Info,    "color:#1a73e8;"),
            4      => (80d,  "Good",     ProgressBarStyle.Success, "color:#26b050;"),
            _      => (100d, "Strong",   ProgressBarStyle.Success, "color:#26b050;")
        };
    }

    private sealed class ResetPasswordModel
    {
        public string? Password { get; set; }
        public string? ConfirmPassword { get; set; }
    }

    private sealed record PasswordRule(string Text, bool Met);
}
