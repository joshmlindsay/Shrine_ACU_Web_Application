    private static string BuildEntryLabel(CarShowEntryDto entry)
    {
        var year = entry.CarDetail?.Year?.ToString() ?? "-";
        var make = string.IsNullOrWhiteSpace(entry.CarDetail?.Make) ? "-" : entry.CarDetail!.Make;
        var model = string.IsNullOrWhiteSpace(entry.CarDetail?.Model) ? "-" : entry.CarDetail!.Model;
        var entryNumber = entry.EntryNumber?.ToString() ?? "-";
        var vin = string.IsNullOrWhiteSpace(entry.Vin) ? "-" : entry.Vin;

        return $"#{entryNumber} - {year} {make} {model} ({vin})";
    }

    private string BuildScoreboardEntryLabel(CarShowFinalScoreDto score)
    {
        if (score.EntryId.HasValue)
        {
            var entryOption = entryOptions.FirstOrDefault(x => x.EntryId == score.EntryId);
            if (entryOption is not null)
            {
                return entryOption.Label;
            }
        }

        return string.IsNullOrWhiteSpace(score.Vin) ? "Unknown entry" : score.Vin!;
    }

    private string GetQuestionLabel(int? questionId)
    {
        return questionId.HasValue && questionLabelsById.TryGetValue(questionId.Value, out var label)
            ? label
            : $"Question {questionId?.ToString() ?? "-"}";
    }

    private string GetQuestionGroupLabel(int? questionCalculationGroupId)
    {
        return questionCalculationGroupId.HasValue && questionGroupLabelsById.TryGetValue(questionCalculationGroupId.Value, out var label)
            ? label
            : $"Group {questionCalculationGroupId?.ToString() ?? "-"}";
    }

    private static bool IsNumericType(string? answerType)
    {
        if (string.IsNullOrWhiteSpace(answerType)) return true;
        var normalized = answerType.Trim().ToLowerInvariant();
        return normalized.Contains("number") || normalized.Contains("numeric") || normalized.Contains("score") || normalized.Contains("decimal") || normalized.Contains("int");
    }

    private static bool IsBooleanType(string? answerType)
    {
        if (string.IsNullOrWhiteSpace(answerType)) return false;
        var normalized = answerType.Trim().ToLowerInvariant();
        return normalized.Contains("bool") || normalized.Contains("yes") || normalized.Contains("no") || normalized.Contains("switch") || normalized.Contains("checkbox");
    }

    private static decimal? ToNullableDecimal(int? value)
    {
        return value.HasValue ? value.Value : null;
    }

    private static string DisplayRange(int? min, int? max)
    {
        if (!min.HasValue && !max.HasValue) return "Any";
        if (!min.HasValue) return $"<= {max}";
        if (!max.HasValue) return $">= {min}";
        return $"{min} - {max}";
    }

    private static string Display(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "-" : value;
    }

    private static string DisplayScore(double? value)
    {
        return value?.ToString("0.##") ?? "-";
    }

    private static string DisplayDateTime(DateTimeOffset? value)
    {
        return value?.ToLocalTime().ToString("MMM dd, yyyy h:mm tt") ?? "-";
    }

    private static string? NullIfWhiteSpace(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? null : value.Trim();
    }

    private static BadgeStyle GetOperationBadgeStyle(string? operationType)
    {
        return NormalizeOperation(operationType) switch
        {
            "SUM" => BadgeStyle.Primary,
            "AVERAGE" => BadgeStyle.Info,
            "MULTIPLY" => BadgeStyle.Success,
            "DIVIDE" => BadgeStyle.Warning,
            "SUBTRACT" => BadgeStyle.Warning,
            "MIN" => BadgeStyle.Secondary,
            "MAX" => BadgeStyle.Secondary,
            _ => BadgeStyle.Light
        };
    }

    private BadgeStyle GetAnswerTypeBadgeStyle(QuestionAnswerModel question)
    {
        if (question.IsBoolean)
        {
            return BadgeStyle.Info;
        }

        if (question.IsNumeric)
        {
            return BadgeStyle.Primary;
        }

        return BadgeStyle.Secondary;
    }

    private static string NormalizeOperation(string? operationType)
    {
        if (string.IsNullOrWhiteSpace(operationType))
        {
            return string.Empty;
        }

        return operationType.Trim().ToUpperInvariant();
    }

    private async Task LoadJudgeOptionsAsync()
    {
        try
        {
            var users = await Client.Api.AppUsers.GetAsync() ?? [];
            judgeOptions = users
                .Where(x => x.IsActive != false)
                .Select(x => new JudgeOption { DisplayName = GetUserDisplayName(x) })
                .Where(x => !string.IsNullOrWhiteSpace(x.DisplayName))
                .GroupBy(x => x.DisplayName, StringComparer.OrdinalIgnoreCase)
                .Select(g => g.First())
                .OrderBy(x => x.DisplayName)
                .ToList();

            EnsureJudgeOption(UserSession.EffectiveDisplayName);
        }
        catch
        {
            judgeOptions = [];
            EnsureJudgeOption(UserSession.EffectiveDisplayName);
        }
    }

    private void SetDefaultJudgeName()
    {
        if (!string.IsNullOrWhiteSpace(judgeName))
        {
            return;
        }

        var preferred = UserSession.EffectiveDisplayName;
        if (string.IsNullOrWhiteSpace(preferred))
        {
            return;
        }

        EnsureJudgeOption(preferred);
        judgeName = judgeOptions
            .FirstOrDefault(x => string.Equals(x.DisplayName, preferred, StringComparison.OrdinalIgnoreCase))
            ?.DisplayName;
    }

    private void EnsureJudgeOption(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return;
        }

        if (judgeOptions.Any(x => string.Equals(x.DisplayName, value, StringComparison.OrdinalIgnoreCase)))
        {
            return;
        }

        judgeOptions.Add(new JudgeOption { DisplayName = value.Trim() });
        judgeOptions = judgeOptions.OrderBy(x => x.DisplayName).ToList();
    }

    private static string GetUserDisplayName(AppUserDto? user)
    {
        if (!string.IsNullOrWhiteSpace(user?.DisplayName))
        {
            return user.DisplayName!;
        }

        var fullName = string.Join(' ', new[] { user?.FirstName, user?.LastName }.Where(x => !string.IsNullOrWhiteSpace(x))).Trim();
        if (!string.IsNullOrWhiteSpace(fullName))
        {
            return fullName;
        }

        return user?.Username ?? string.Empty;
    }

