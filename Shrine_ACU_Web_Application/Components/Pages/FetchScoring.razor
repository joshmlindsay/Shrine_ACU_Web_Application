    private sealed class QuestionAnswerModel
    {
        public int? QuestionId { get; set; }
        public string QuestionText { get; set; } = string.Empty;
        public string? AnswerType { get; set; }
        public bool Required { get; set; }
        public int? MinScore { get; set; }
        public int? MaxScore { get; set; }
        public int? AnswerId { get; set; }
        public DateTimeOffset? AnsweredDate { get; set; }
        public DateTimeOffset? LastModified { get; set; }
        public string? SavedBy { get; set; }

        public bool IsNumeric { get; set; }
        public bool IsBoolean { get; set; }

        public double? NumericAnswer { get; set; }
        public bool? BooleanAnswer { get; set; }
        public string? TextAnswer { get; set; }
        public string? Comments { get; set; }

        public string DisplayAnswerType => IsBoolean ? "Boolean" : IsNumeric ? "Numeric" : string.IsNullOrWhiteSpace(AnswerType) ? "Text" : AnswerType!;

        public bool HasValue()
        {
            if (IsBoolean)
            {
                return BooleanAnswer.HasValue;
            }

            if (IsNumeric)
            {
                return NumericAnswer.HasValue;
            }

            return !string.IsNullOrWhiteSpace(TextAnswer);
        }
    }

