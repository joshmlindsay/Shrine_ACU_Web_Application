@page "/"

@rendermode InteractiveServer

@inject UserSessionService UserSession

<PageTitle>Home</PageTitle>

<RadzenStack Gap="1rem">
    <RadzenText TextStyle="TextStyle.H4">Shrine ACU Portal</RadzenText>
    @if (!UserSession.IsAuthenticated)
    {
        <RadzenAlert AlertStyle="AlertStyle.Warning">You must log in to use this portal. Click the Login link in the navigation menu.</RadzenAlert>
    }
    else
    {
        <RadzenText>Hello World</RadzenText>
    }
</RadzenStack>
