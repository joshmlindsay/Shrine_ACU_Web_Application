@page "/fetch-payments"
@rendermode InteractiveServer

@inject AcuCarShowClient Client
@inject NavigationManager Navigation
@inject UserSessionService UserSession
@inject IJSRuntime JSRuntime

<PageTitle>Payment Operations</PageTitle>

@if (!UserSession.IsAuthenticated)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning">You must log in before viewing payment operations.</RadzenAlert>
}
else if (!UserSession.CanManage)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning">Your account does not have permission to view payment operations.</RadzenAlert>
}
else
{
    <RadzenStack Gap="1rem">
        <RadzenRow AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
            <RadzenColumn Size="12" SizeMD="8">
                <RadzenText TextStyle="TextStyle.H4">Payment Operations Dashboard</RadzenText>
                <RadzenText TextStyle="TextStyle.Caption">Acting user: @UserSession.EffectiveDisplayName</RadzenText>
            </RadzenColumn>
            <RadzenColumn Size="12" SizeMD="4">
                <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem" Wrap="FlexWrap.Wrap">
                    <RadzenButton Text="Refresh" Icon="refresh" ButtonStyle="ButtonStyle.Light" Click="LoadAsync" Disabled="isLoading || isExporting" Style="flex: 0 1 auto;" />
                    <RadzenButton Text="Export CSV" Icon="download" ButtonStyle="ButtonStyle.Secondary" Click="ExportCsvAsync" Disabled="isLoading || isExporting || !filteredEntries.Any()" Style="flex: 0 1 auto;" />
                    <RadzenButton Text="Export Exceptions" Icon="warning" ButtonStyle="ButtonStyle.Warning" Click="ExportExceptionsCsvAsync" Disabled="isLoading || isExporting || !filteredEntries.Any()" Style="flex: 0 1 auto;" />
                    <RadzenButton Text="Export Daily Summary" Icon="summarize" ButtonStyle="ButtonStyle.Info" Click="ExportDailySummaryCsvAsync" Disabled="isLoading || isExporting || !filteredEntries.Any()" Style="flex: 0 1 auto;" />
                    <RadzenButton Text="Manage Entries" Icon="list_alt" ButtonStyle="ButtonStyle.Primary" Click="GoToCarShows" Style="flex: 0 1 auto;" />
                </RadzenStack>
            </RadzenColumn>
        </RadzenRow>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <RadzenAlert AlertStyle="AlertStyle.Danger">@errorMessage</RadzenAlert>
        }

        @if (isLoading)
        {
            <RadzenProgressBarCircular Mode="ProgressBarMode.Indeterminate" />
        }
        else
        {
            <RadzenCard>
                <RadzenStack Gap="1rem">
                    <RadzenText TextStyle="TextStyle.H6">Filters</RadzenText>
                    <RadzenRow Gap="1rem">
                        <RadzenColumn Size="12" SizeMD="4">
                            <RadzenFormField Text="Show" Variant="Variant.Outlined" Style="width:100%;">
                                <RadzenDropDown TValue="int?"
                                                Data="@carShows"
                                                TextProperty="Name"
                                                ValueProperty="ShowId"
                                                @bind-Value="selectedShowId"
                                                Change="OnFilterChanged"
                                                AllowClear="true"
                                                Placeholder="All shows"
                                                Style="width:100%;" />
                            </RadzenFormField>
                        </RadzenColumn>
                        <RadzenColumn Size="12" SizeMD="4">
                            <RadzenFormField Text="Payment Status" Variant="Variant.Outlined" Style="width:100%;">
                                <RadzenDropDown TValue="string"
                                                Data="@paymentStatusOptions"
                                                TextProperty="Label"
                                                ValueProperty="Value"
                                                @bind-Value="selectedPaymentStatus"
                                                Change="OnFilterChanged"
                                                AllowClear="true"
                                                Placeholder="All statuses"
                                                Style="width:100%;" />
                            </RadzenFormField>
                        </RadzenColumn>
                        <RadzenColumn Size="12" SizeMD="4">
                            <RadzenFormField Text="Payment Method" Variant="Variant.Outlined" Style="width:100%;">
                                <RadzenDropDown TValue="string"
                                                Data="@paymentMethodOptions"
                                                TextProperty="Label"
                                                ValueProperty="Value"
                                                @bind-Value="selectedPaymentMethod"
                                                Change="OnFilterChanged"
                                                AllowClear="true"
                                                Placeholder="All methods"
                                                Style="width:100%;" />
                            </RadzenFormField>
                        </RadzenColumn>
                    </RadzenRow>

                    <RadzenRow Gap="1rem">
                        <RadzenColumn Size="12" SizeMD="3">
                            <RadzenCheckBox TValue="bool" Value="@onlyPendingOlderThanThreshold" Change="OnOnlyPendingChanged" />
                            <RadzenText TextStyle="TextStyle.Body2" Style="margin-left:0.5rem;">Pending older than 15 minutes</RadzenText>
                        </RadzenColumn>
                        <RadzenColumn Size="12" SizeMD="3">
                            <RadzenCheckBox TValue="bool" Value="@onlyMissingProof" Change="OnOnlyMissingProofChanged" />
                            <RadzenText TextStyle="TextStyle.Body2" Style="margin-left:0.5rem;">Missing proof reference</RadzenText>
                        </RadzenColumn>
                    </RadzenRow>
                </RadzenStack>
            </RadzenCard>

            <RadzenRow Gap="1rem">
                <RadzenColumn Size="12" SizeMD="2"><RadzenCard><RadzenText><b>Total:</b> @(serverSummary?.TotalCount ?? 0)</RadzenText></RadzenCard></RadzenColumn>
                <RadzenColumn Size="12" SizeMD="2"><RadzenCard><RadzenText><b>Paid:</b> @(serverSummary?.PaidCount ?? 0)</RadzenText></RadzenCard></RadzenColumn>
                <RadzenColumn Size="12" SizeMD="2"><RadzenCard><RadzenText><b>Pending:</b> @(serverSummary?.PendingCount ?? 0)</RadzenText></RadzenCard></RadzenColumn>
                <RadzenColumn Size="12" SizeMD="3"><RadzenCard><RadzenText><b>Collected:</b> @DisplayAmount(serverSummary?.CollectedAmount)</RadzenText></RadzenCard></RadzenColumn>
                <RadzenColumn Size="12" SizeMD="3"><RadzenCard><RadzenText><b>Manual Updates:</b> @(serverSummary?.ManualCount ?? 0)</RadzenText></RadzenCard></RadzenColumn>
            </RadzenRow>

            <RadzenCard>
                <RadzenStack Gap="0.5rem">
                    <RadzenText TextStyle="TextStyle.H6">Reconciliation Snapshot (Authoritative API)</RadzenText>
                    <RadzenText><b>Expected Collected:</b> @DisplayAmount(serverSummary?.ExpectedCollected)</RadzenText>
                    <RadzenText><b>Actual Collected:</b> @DisplayAmount(serverSummary?.CollectedAmount)</RadzenText>
                    <RadzenText><b>Variance:</b> @DisplayAmount(serverSummary?.Variance)</RadzenText>
                    @if (!string.IsNullOrWhiteSpace(summaryMessage))
                    {
                        <RadzenText TextStyle="TextStyle.Caption">@summaryMessage</RadzenText>
                    }
                </RadzenStack>
            </RadzenCard>

            <RadzenDataGrid Data="@filteredEntries" TItem="CarShowEntryDto" AllowPaging="true" PageSize="12" EmptyText="No payment records match the selected filters.">
                <Columns>
                    <RadzenDataGridColumn TItem="CarShowEntryDto" Property="EntryNumber" Title="#" Width="70px" />
                    <RadzenDataGridColumn TItem="CarShowEntryDto" Property="ShowId" Title="Show" Width="90px" />
                    <RadzenDataGridColumn TItem="CarShowEntryDto" Property="Vin" Title="VIN" Width="180px" />
                    <RadzenDataGridColumn TItem="CarShowEntryDto" Property="PaymentStatus" Title="Status" Width="110px" />
                    <RadzenDataGridColumn TItem="CarShowEntryDto" Property="PreferredPaymentMethod" Title="Method" Width="130px" />
                    <RadzenDataGridColumn TItem="CarShowEntryDto" Property="PaymentProvider" Title="Provider" Width="110px" />
                    <RadzenDataGridColumn TItem="CarShowEntryDto" Title="Paid" Width="110px">
                        <Template Context="item">@DisplayAmount(item.PaidAmount)</Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="CarShowEntryDto" Title="Paid At" Width="150px">
                        <Template Context="item">@DisplayDateTime(item.PaidAtUtc)</Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="CarShowEntryDto" Property="PaymentProofReference" Title="Proof" Width="180px" />
                    <RadzenDataGridColumn TItem="CarShowEntryDto" Title="Registered" Width="150px">
                        <Template Context="item">@DisplayDateTime(item.RegistrationDate)</Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        }
    </RadzenStack>
}

@code {
    private static readonly TimeSpan PendingThreshold = TimeSpan.FromMinutes(15);

    private readonly IReadOnlyList<SelectionOption> paymentStatusOptions =
    [
        new("Pending", "Pending"),
        new("Paid", "Paid"),
        new("Waived", "Waived"),
        new("Refunded", "Refunded")
    ];

    private readonly IReadOnlyList<SelectionOption> paymentMethodOptions =
    [
        new("Cash App Pay", "CashAppPay"),
        new("Venmo", "Venmo"),
        new("Apple Pay", "ApplePay"),
        new("Google Pay", "GooglePay"),
        new("Cash", "Cash")
    ];

    private List<CarShowDto> carShows = [];
    private List<CarShowEntryDto> allEntries = [];
    private List<CarShowEntryDto> filteredEntries = [];

    private int? selectedShowId;
    private string? selectedPaymentStatus;
    private string? selectedPaymentMethod;
    private bool onlyPendingOlderThanThreshold;
    private bool onlyMissingProof;

    private bool isLoading;
    private bool isExporting;
    private string? errorMessage;
    private string? summaryMessage;
    private PaymentOperationsSummaryDto? serverSummary;

    protected override async Task OnInitializedAsync()
    {
        if (!UserSession.IsAuthenticated)
        {
            Navigation.NavigateTo($"/fetch-login?returnUrl={Uri.EscapeDataString("/fetch-payments")}");
            return;
        }

        if (!UserSession.CanManage)
        {
            Navigation.NavigateTo("/", replace: true);
            return;
        }

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        errorMessage = null;
        summaryMessage = null;
        isLoading = true;

        try
        {
            var shows = await Client.Api.CarShows.GetAsync();
            carShows = shows?.Where(x => x.ShowId.HasValue).OrderBy(x => x.Name).ToList() ?? [];

            var entries = await Client.Api.CarShowEntries.GetAsync();
            allEntries = entries?.OrderByDescending(x => x.RegistrationDate ?? DateTimeOffset.MinValue).ToList() ?? [];

            ApplyFilters();
            await LoadServerSummaryAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Unable to load payment operations data. {ex.Message}";
            filteredEntries = [];
            allEntries = [];
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadServerSummaryAsync()
    {
        try
        {
            serverSummary = await Client.Api.Payments.Operations.Summary.GetAsync(config =>
            {
                config.QueryParameters.ShowId = selectedShowId;
            });

            summaryMessage = serverSummary is null
                ? "API summary is not available for current show filter."
                : $"API totals: Total={serverSummary.TotalCount ?? 0}, Paid={serverSummary.PaidCount ?? 0}, Pending={serverSummary.PendingCount ?? 0}, Manual={serverSummary.ManualCount ?? 0}.";
        }
        catch (Exception ex)
        {
            summaryMessage = $"Unable to load API summary. {ex.Message}";
        }
    }

    private async Task ExportCsvAsync()
    {
        await ExportFromApiAsync("full");
    }

    private async Task ExportExceptionsCsvAsync()
    {
        await ExportFromApiAsync("exceptions");
    }

    private async Task ExportDailySummaryCsvAsync()
    {
        await ExportFromApiAsync("daily");
    }

    private async Task ExportFromApiAsync(string type)
    {
        isExporting = true;
        errorMessage = null;

        try
        {
            using var stream = await Client.Api.Payments.Operations.Export.GetAsync(config =>
            {
                config.QueryParameters.Type = type;
                config.QueryParameters.ShowId = selectedShowId;
                if (string.Equals(type, "exceptions", StringComparison.OrdinalIgnoreCase))
                {
                    config.QueryParameters.MissingProof = onlyMissingProof ? true : null;
                    config.QueryParameters.PendingMinutesThreshold = onlyPendingOlderThanThreshold ? (int)PendingThreshold.TotalMinutes : null;
                }
            });

            if (stream is null)
            {
                errorMessage = "Export failed because no file content was returned by the API.";
                return;
            }

            using var memoryStream = new MemoryStream();
            await stream.CopyToAsync(memoryStream);
            var bytes = memoryStream.ToArray();
            if (bytes.Length == 0)
            {
                errorMessage = "Export failed because API returned an empty file.";
                return;
            }

            var base64 = Convert.ToBase64String(bytes);
            var fileName = BuildExportFileName(type);
            await JSRuntime.InvokeVoidAsync("shrineDownload.downloadFileFromBase64", fileName, "text/csv;charset=utf-8", base64);
        }
        catch (Exception ex)
        {
            errorMessage = $"Unable to export {type} CSV. {ex.Message}";
        }
        finally
        {
            isExporting = false;
        }
    }

    private static string BuildExportFileName(string type)
    {
        var suffix = string.Equals(type, "exceptions", StringComparison.OrdinalIgnoreCase)
            ? "exceptions"
            : string.Equals(type, "daily", StringComparison.OrdinalIgnoreCase)
                ? "daily-summary"
                : "operations";

        return $"payment-{suffix}-{DateTime.UtcNow:yyyyMMdd-HHmmss}.csv";
    }

    private async Task OnFilterChanged(object? _)
    {
        ApplyFilters();
        await LoadServerSummaryAsync();
    }

    private async Task OnOnlyPendingChanged(bool value)
    {
        onlyPendingOlderThanThreshold = value;
        ApplyFilters();
        await LoadServerSummaryAsync();
    }

    private async Task OnOnlyMissingProofChanged(bool value)
    {
        onlyMissingProof = value;
        ApplyFilters();
        await LoadServerSummaryAsync();
    }

    private void ApplyFilters()
    {
        var now = DateTimeOffset.UtcNow;

        IEnumerable<CarShowEntryDto> query = allEntries;

        if (selectedShowId.HasValue)
        {
            query = query.Where(x => x.ShowId == selectedShowId.Value);
        }

        if (!string.IsNullOrWhiteSpace(selectedPaymentStatus))
        {
            query = query.Where(x => string.Equals(x.PaymentStatus, selectedPaymentStatus, StringComparison.OrdinalIgnoreCase));
        }

        if (!string.IsNullOrWhiteSpace(selectedPaymentMethod))
        {
            query = query.Where(x => string.Equals(x.PreferredPaymentMethod, selectedPaymentMethod, StringComparison.OrdinalIgnoreCase));
        }

        if (onlyPendingOlderThanThreshold)
        {
            query = query.Where(x => string.Equals(x.PaymentStatus, "Pending", StringComparison.OrdinalIgnoreCase)
                                     && x.RegistrationDate.HasValue
                                     && now - x.RegistrationDate.Value > PendingThreshold);
        }

        if (onlyMissingProof)
        {
            query = query.Where(x => string.IsNullOrWhiteSpace(x.PaymentProofReference));
        }

        filteredEntries = query.ToList();
    }

    private void GoToCarShows()
    {
        Navigation.NavigateTo("/fetch-carshows");
    }

    private static string DisplayAmount(double? value)
    {
        return value.HasValue ? value.Value.ToString("C") : "-";
    }

    private static string DisplayDateTime(DateTimeOffset? value)
    {
        return value?.ToLocalTime().ToString("MMM dd, yyyy h:mm tt") ?? "-";
    }

    private sealed record SelectionOption(string Label, string Value);
}
