<RadzenStack Gap="1rem">
    <RadzenText TextStyle="TextStyle.H5">Vehicle Summary</RadzenText>

    <RadzenRow>
        <RadzenColumn Size="12" SizeMD="6"><b>VIN:</b> @ValueOrDash(CarDetail?.Vin)</RadzenColumn>
        <RadzenColumn Size="12" SizeMD="6"><b>Owner:</b> @ValueOrDash(CarDetail?.Owner)</RadzenColumn>
    </RadzenRow>
    <RadzenRow>
        <RadzenColumn Size="12" SizeMD="4"><b>Year:</b> @ValueOrDash(CarDetail?.Year)</RadzenColumn>
        <RadzenColumn Size="12" SizeMD="4"><b>Make:</b> @ValueOrDash(CarDetail?.Make)</RadzenColumn>
        <RadzenColumn Size="12" SizeMD="4"><b>Model:</b> @ValueOrDash(CarDetail?.Model)</RadzenColumn>
    </RadzenRow>
    <RadzenRow>
        <RadzenColumn Size="12" SizeMD="4"><b>Color:</b> @ValueOrDash(CarDetail?.Color)</RadzenColumn>
        <RadzenColumn Size="12" SizeMD="4"><b>Body Type:</b> @ValueOrDash(CarDetail?.BodyType)</RadzenColumn>
        <RadzenColumn Size="12" SizeMD="4"><b>Mileage:</b> @ValueOrDash(CarDetail?.Mileage)</RadzenColumn>
    </RadzenRow>
    <RadzenRow>
        <RadzenColumn Size="12" SizeMD="6"><b>Transmission:</b> @ValueOrDash(CarDetail?.Transmission)</RadzenColumn>
        <RadzenColumn Size="12" SizeMD="6"><b>Fuel Type:</b> @ValueOrDash(CarDetail?.FuelType)</RadzenColumn>
    </RadzenRow>
</RadzenStack>

@code {
    [Parameter]
    public CarDetailDto? CarDetail { get; set; }

    private static string ValueOrDash(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "-" : value;
    }

    private static string ValueOrDash(int? value)
    {
        return value?.ToString() ?? "-";
    }
}
