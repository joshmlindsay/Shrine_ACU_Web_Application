@page "/fetch-signup"
@page "/fetch-signup/{ShowId:int}"
@rendermode InteractiveServer
@inject AcuCarShowClient Client
@inject NavigationManager Navigation
@inject UserSessionService UserSession

<PageTitle>Car Show Signup</PageTitle>

@if (!UserSession.IsAuthenticated)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning">You must log in before submitting signups.</RadzenAlert>
}
else if (!UserSession.CanWrite)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning">Your account does not have permission to submit signups.</RadzenAlert>
}
else
{
    <RadzenStack Gap="1rem">
        <RadzenText TextStyle="TextStyle.H4">Car Show Signup</RadzenText>
        <RadzenText TextStyle="TextStyle.Body2">Acting user: <b>@UserSession.EffectiveDisplayName</b></RadzenText>
        <RadzenText TextStyle="TextStyle.Body2">You can open this page directly, or pass a show id like <b>/fetch-signup/5</b> or <b>/fetch-signup?carshowid=5</b>.</RadzenText>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <RadzenAlert AlertStyle="AlertStyle.Danger">@errorMessage</RadzenAlert>
        }

        @if (!string.IsNullOrWhiteSpace(successMessage))
        {
            <RadzenAlert AlertStyle="AlertStyle.Success">@successMessage</RadzenAlert>
        }

        @if (isLoading)
        {
            <RadzenProgressBarCircular Mode="ProgressBarMode.Indeterminate" />
        }
        else
        {
            <RadzenTemplateForm TItem="SignupFormModel" Data="@form" Submit="@SubmitSignup">
                <RadzenCard>
                    <RadzenStack Gap="1rem">
                        <RadzenText TextStyle="TextStyle.H5">Show Selection</RadzenText>

                        <RadzenRow>
                            <RadzenColumn Size="12" SizeMD="6">
                                <RadzenFormField Text="Car Show" Variant="Variant.Outlined" Style="width:100%;">
                                    <RadzenDropDown Name="ShowId"
                                                    TValue="int?"
                                                    Data="@carShows"
                                                    TextProperty="Name"
                                                    ValueProperty="ShowId"
                                                    @bind-Value="form.ShowId"
                                                    Placeholder="Select a car show"
                                                    Style="width:100%;" />
                                </RadzenFormField>
                                <RadzenRequiredValidator Component="ShowId" Text="Car show is required" Popup="true" />
                            </RadzenColumn>
                        </RadzenRow>

                        <RadzenText TextStyle="TextStyle.H5">Personal Information</RadzenText>

                        <RadzenRow Gap="1rem">
                            <RadzenColumn Size="12" SizeMD="6">
                                <RadzenFormField Text="First Name" Variant="Variant.Outlined" Style="width:100%;">
                                    <RadzenTextBox Name="FirstName" @bind-Value="form.FirstName" Style="width:100%;" />
                                </RadzenFormField>
                                <RadzenRequiredValidator Component="FirstName" Text="First name is required" Popup="true" />
                            </RadzenColumn>
                            <RadzenColumn Size="12" SizeMD="6">
                                <RadzenFormField Text="Last Name" Variant="Variant.Outlined" Style="width:100%;">
                                    <RadzenTextBox Name="LastName" @bind-Value="form.LastName" Style="width:100%;" />
                                </RadzenFormField>
                                <RadzenRequiredValidator Component="LastName" Text="Last name is required" Popup="true" />
                            </RadzenColumn>
                        </RadzenRow>

                        <RadzenRow Gap="1rem">
                            <RadzenColumn Size="12" SizeMD="6">
                                <RadzenFormField Text="Email" Variant="Variant.Outlined" Style="width:100%;">
                                    <RadzenTextBox Name="Email" @bind-Value="form.Email" Style="width:100%;" />
                                </RadzenFormField>
                                <RadzenRequiredValidator Component="Email" Text="Email is required" Popup="true" />
                                <RadzenEmailValidator Component="Email" Text="Enter a valid email" Popup="true" />
                            </RadzenColumn>
                            <RadzenColumn Size="12" SizeMD="6">
                                <RadzenFormField Text="Phone" Variant="Variant.Outlined" Style="width:100%;">
                                    <RadzenTextBox Name="Phone" @bind-Value="form.Phone" Style="width:100%;" />
                                </RadzenFormField>
                            </RadzenColumn>
                        </RadzenRow>

                        <RadzenText TextStyle="TextStyle.H5">Car Information</RadzenText>

                        <RadzenRow Gap="1rem">
                            <RadzenColumn Size="12" SizeMD="4">
                                <RadzenFormField Text="Year" Variant="Variant.Outlined" Style="width:100%;">
                                    <RadzenNumeric Name="Year" TValue="int?" @bind-Value="form.Year" Style="width:100%;" Min="1900" Max="2100" />
                                </RadzenFormField>
                                <RadzenRequiredValidator Component="Year" Text="Year is required" Popup="true" />
                            </RadzenColumn>
                            <RadzenColumn Size="12" SizeMD="4">
                                <RadzenFormField Text="Make" Variant="Variant.Outlined" Style="width:100%;">
                                    <RadzenTextBox Name="Make" @bind-Value="form.Make" Style="width:100%;" />
                                </RadzenFormField>
                                <RadzenRequiredValidator Component="Make" Text="Make is required" Popup="true" />
                            </RadzenColumn>
                            <RadzenColumn Size="12" SizeMD="4">
                                <RadzenFormField Text="Model" Variant="Variant.Outlined" Style="width:100%;">
                                    <RadzenTextBox Name="Model" @bind-Value="form.Model" Style="width:100%;" />
                                </RadzenFormField>
                                <RadzenRequiredValidator Component="Model" Text="Model is required" Popup="true" />
                            </RadzenColumn>
                        </RadzenRow>

                        <RadzenRow Gap="1rem">
                            <RadzenColumn Size="12" SizeMD="6">
                                <RadzenFormField Text="VIN" Variant="Variant.Outlined" Style="width:100%;">
                                    <RadzenTextBox Name="Vin" @bind-Value="form.Vin" Style="width:100%;" />
                                </RadzenFormField>
                                <RadzenRequiredValidator Component="Vin" Text="VIN is required" Popup="true" />
                            </RadzenColumn>
                            <RadzenColumn Size="12" SizeMD="6">
                                <RadzenFormField Text="Color" Variant="Variant.Outlined" Style="width:100%;">
                                    <RadzenTextBox Name="Color" @bind-Value="form.Color" Style="width:100%;" />
                                </RadzenFormField>
                            </RadzenColumn>
                        </RadzenRow>

                        <RadzenText TextStyle="TextStyle.H5">Payment Preference</RadzenText>

                        <RadzenRow Gap="1rem">
                            <RadzenColumn Size="12" SizeMD="6">
                                <RadzenFormField Text="When will you pay?" Variant="Variant.Outlined" Style="width:100%;">
                                    <RadzenDropDown Name="PaymentTiming"
                                                    TValue="string"
                                                    Data="@paymentTimingOptions"
                                                    TextProperty="Label"
                                                    ValueProperty="Value"
                                                    Value="@form.PaymentTiming"
                                                    Change="OnPaymentTimingChanged"
                                                    Style="width:100%;" />
                                </RadzenFormField>
                                <RadzenRequiredValidator Component="PaymentTiming" Text="Payment timing is required" Popup="true" />
                            </RadzenColumn>

                            <RadzenColumn Size="12" SizeMD="6">
                                <RadzenFormField Text="Preferred payment method" Variant="Variant.Outlined" Style="width:100%;">
                                    <RadzenDropDown Name="PaymentMethod"
                                                    TValue="string"
                                                    Data="@paymentMethodOptions"
                                                    TextProperty="Label"
                                                    ValueProperty="Value"
                                                    @bind-Value="form.PaymentMethod"
                                                    AllowClear="true"
                                                    Placeholder="Select preferred method"
                                                    Style="width:100%;" />
                                </RadzenFormField>
                                @if (RequiresOnlinePaymentMethod)
                                {
                                    <RadzenRequiredValidator Component="PaymentMethod" Text="Select a payment method when paying online now" Popup="true" />
                                }
                            </RadzenColumn>
                        </RadzenRow>

                        <RadzenRow Gap="1rem">
                            <RadzenColumn Size="12" SizeMD="6">
                                <RadzenFormField Text="Payment amount (optional)" Variant="Variant.Outlined" Style="width:100%;">
                                    <RadzenNumeric TValue="double?" @bind-Value="form.PaymentAmount" Min="0" Step="1" Style="width:100%;" />
                                </RadzenFormField>
                            </RadzenColumn>
                            <RadzenColumn Size="12" SizeMD="6">
                                <RadzenFormField Text="Payment confirmation / receipt #" Variant="Variant.Outlined" Style="width:100%;">
                                    <RadzenTextBox @bind-Value="form.PaymentProofReference" Style="width:100%;" />
                                </RadzenFormField>
                            </RadzenColumn>
                        </RadzenRow>

                        <RadzenRow Gap="1rem">
                            <RadzenColumn Size="12" SizeMD="6">
                                <RadzenFormField Text="Payment notes for event manager" Variant="Variant.Outlined" Style="width:100%;">
                                    <RadzenTextArea @bind-Value="form.PaymentNote" Style="width:100%;" Rows="2" />
                                </RadzenFormField>
                            </RadzenColumn>
                        </RadzenRow>

                        <RadzenButton Text="Submit Signup"
                                      ButtonType="ButtonType.Submit"
                                      ButtonStyle="ButtonStyle.Primary"
                                      Icon="save"
                                      Disabled="isSubmitting" />
                    </RadzenStack>
                </RadzenCard>
            </RadzenTemplateForm>
        }
    </RadzenStack>
}

@code {
    private const string PaymentTimingPayOnlineNow = "PayOnlineNow";
    private const string PaymentTimingPayLater = "PayLater";
    private const string PaymentTimingPayAtEvent = "PayAtEvent";

    private const string PaymentMethodCashAppPay = "CashAppPay";
    private const string PaymentMethodVenmo = "Venmo";
    private const string PaymentMethodApplePay = "ApplePay";
    private const string PaymentMethodGooglePay = "GooglePay";
    private const string PaymentMethodCash = "Cash";

    [Parameter]
    public int? ShowId { get; set; }

    [SupplyParameterFromQuery(Name = "carshowid")]
    public int? CarShowIdQuery { get; set; }

    private readonly IReadOnlyList<SelectionOption> paymentTimingOptions =
    [
        new("Pay online now", PaymentTimingPayOnlineNow),
        new("Pay later", PaymentTimingPayLater),
        new("Pay at event (in person)", PaymentTimingPayAtEvent)
    ];

    private readonly IReadOnlyList<SelectionOption> paymentMethodOptions =
    [
        new("Cash App Pay", PaymentMethodCashAppPay),
        new("Venmo", PaymentMethodVenmo),
        new("Apple Pay", PaymentMethodApplePay),
        new("Google Pay (Android)", PaymentMethodGooglePay),
        new("Cash (in person)", PaymentMethodCash)
    ];

    private List<CarShowDto> carShows = [];
    private SignupFormModel form = new();
    private bool isLoading = true;
    private bool isSubmitting;
    private string? errorMessage;
    private string? successMessage;

    private bool RequiresOnlinePaymentMethod => string.Equals(form.PaymentTiming, PaymentTimingPayOnlineNow, StringComparison.Ordinal);

    protected override async Task OnInitializedAsync()
    {
        if (!UserSession.IsAuthenticated)
        {
            Navigation.NavigateTo($"/fetch-login?returnUrl={Uri.EscapeDataString("/fetch-signup")}");
            return;
        }

        if (!UserSession.CanWrite)
        {
            Navigation.NavigateTo("/", replace: true);
            return;
        }

        PrefillFromEffectiveUser();
        await LoadShowsAsync();
        ApplyPrefilledShowId();
    }

    protected override void OnParametersSet()
    {
        if (!UserSession.IsAuthenticated || !UserSession.CanWrite)
        {
            return;
        }

        PrefillFromEffectiveUser();
        ApplyPrefilledShowId();
    }

    private async Task LoadShowsAsync()
    {
        try
        {
            var response = await Client.Api.CarShows.GetAsync();
            carShows = response?.Where(x => x.ShowId.HasValue).OrderBy(x => x.Name).ToList() ?? [];
        }
        catch (Exception ex)
        {
            errorMessage = $"Unable to load car shows. {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ApplyPrefilledShowId()
    {
        var preferredShowId = ShowId ?? CarShowIdQuery;

        if (!preferredShowId.HasValue)
        {
            return;
        }

        var exists = carShows.Any(x => x.ShowId == preferredShowId.Value);
        if (exists)
        {
            form.ShowId = preferredShowId.Value;
        }
    }

    private void OnPaymentTimingChanged(object? value)
    {
        form.PaymentTiming = value?.ToString() ?? PaymentTimingPayLater;
    }

    private async Task SubmitSignup(SignupFormModel _)
    {
        errorMessage = null;
        successMessage = null;

        if (RequiresOnlinePaymentMethod)
        {
            if (!IsOnlinePaymentMethod(form.PaymentMethod))
            {
                errorMessage = "Select Cash App Pay, Venmo, Apple Pay, or Google Pay when paying online now.";
                return;
            }

            if (!form.PaymentAmount.HasValue || form.PaymentAmount.Value <= 0)
            {
                errorMessage = "Payment amount is required when paying online now.";
                return;
            }
        }

        isSubmitting = true;

        try
        {
            var selectedShow = carShows.FirstOrDefault(x => x.ShowId == form.ShowId);

            var entry = new CarShowEntryDto
            {
                ShowId = form.ShowId,
                Vin = form.Vin,
                Category = selectedShow?.Category,
                Status = "Pending",
                RegistrationDate = DateTimeOffset.UtcNow,
                SubmittedByUserId = UserSession.EffectiveUserId,
                PaymentTiming = form.PaymentTiming,
                PreferredPaymentMethod = form.PaymentMethod,
                PaymentProofReference = NullIfWhiteSpace(form.PaymentProofReference),
                PaidAmount = form.PaymentAmount,
                PaymentStatus = "Pending",
                PaymentProvider = ResolvePaymentProvider(form.PaymentMethod),
                CarDetail = new CarDetailDto
                {
                    Vin = form.Vin,
                    Year = form.Year,
                    Make = form.Make,
                    Model = form.Model,
                    Color = form.Color,
                    Owner = $"{form.FirstName} {form.LastName}".Trim(),
                    Status = "Pending"
                },
                Notes = BuildContactNotes()
            };

            var createdEntry = await Client.Api.CarShowEntries.PostAsync(entry);

            if (RequiresOnlinePaymentMethod)
            {
                if (createdEntry?.EntryId is not int entryId)
                {
                    successMessage = "Signup submitted, but payment session could not be started because entry id was not returned.";
                    return;
                }

                var baseUri = Navigation.BaseUri.TrimEnd('/');
                var successUrl = $"{baseUri}/payment-return?entryId={entryId}&result=success";
                var cancelUrl = $"{baseUri}/payment-return?entryId={entryId}&result=cancel";

                var sessionRequest = new CarShowEntryPaymentSessionRequestDto
                {
                    Amount = form.PaymentAmount,
                    PaymentProvider = ResolvePaymentProvider(form.PaymentMethod),
                    PreferredPaymentMethod = form.PaymentMethod,
                    SuccessUrl = successUrl,
                    CancelUrl = cancelUrl
                };

                var session = await Client.Api.CarShowEntries[entryId].Payment.Session.PostAsync(sessionRequest);
                if (string.IsNullOrWhiteSpace(session?.CheckoutUrl))
                {
                    successMessage = "Signup submitted, but checkout URL was not returned. You can complete payment later.";
                    return;
                }

                Navigation.NavigateTo(session.CheckoutUrl, forceLoad: true);
                return;
            }

            successMessage = "Signup submitted successfully.";
            form = new SignupFormModel
            {
                ShowId = form.ShowId,
                FirstName = UserSession.EffectiveUser?.FirstName,
                LastName = UserSession.EffectiveUser?.LastName,
                Email = UserSession.EffectiveUser?.Email
            };
        }
        catch (Exception ex)
        {
            errorMessage = $"Unable to submit signup. {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private static bool IsOnlinePaymentMethod(string? paymentMethod)
    {
        return paymentMethod is PaymentMethodCashAppPay or PaymentMethodVenmo or PaymentMethodApplePay or PaymentMethodGooglePay;
    }

    private static string? ResolvePaymentProvider(string? paymentMethod)
    {
        return paymentMethod switch
        {
            PaymentMethodVenmo => "Braintree",
            PaymentMethodCash => "Manual",
            PaymentMethodCashAppPay or PaymentMethodApplePay or PaymentMethodGooglePay => "Stripe",
            _ => null
        };
    }

    private void PrefillFromEffectiveUser()
    {
        form.FirstName = UserSession.EffectiveUser?.FirstName;
        form.LastName = UserSession.EffectiveUser?.LastName;
        form.Email = UserSession.EffectiveUser?.Email;
    }

    private string BuildContactNotes()
    {
        var parts = new List<string>
        {
            $"Name: {form.FirstName} {form.LastName}".Trim(),
            $"Email: {form.Email}",
            $"Phone: {form.Phone}"
        };

        if (!string.IsNullOrWhiteSpace(form.PaymentNote))
        {
            parts.Add($"PaymentNote: {form.PaymentNote}");
        }

        return string.Join("; ", parts.Where(x => !string.IsNullOrWhiteSpace(x)));
    }

    private static string? NullIfWhiteSpace(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? null : value.Trim();
    }

    private sealed class SignupFormModel
    {
        public int? ShowId { get; set; }
        public string? FirstName { get; set; }
        public string? LastName { get; set; }
        public string? Email { get; set; }
        public string? Phone { get; set; }
        public int? Year { get; set; }
        public string? Make { get; set; }
        public string? Model { get; set; }
        public string? Vin { get; set; }
        public string? Color { get; set; }
        public string PaymentTiming { get; set; } = PaymentTimingPayLater;
        public string? PaymentMethod { get; set; }
        public double? PaymentAmount { get; set; }
        public string? PaymentProofReference { get; set; }
        public string? PaymentNote { get; set; }
    }

    private sealed record SelectionOption(string Label, string Value);
}
