@inject DialogService DialogService
@inject AcuCarShowClient Client

<RadzenStack Gap="1rem" Style="min-width:380px;max-width:520px;">
    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <RadzenAlert AlertStyle="AlertStyle.Danger">@errorMessage</RadzenAlert>
    }

    @if (isLoading)
    {
        <RadzenProgressBarCircular Mode="ProgressBarMode.Indeterminate" />
        <RadzenText TextStyle="TextStyle.Body2">Loading payment details...</RadzenText>
    }
    else
    {
        <RadzenText TextStyle="TextStyle.Body2">
            Entry: <b>@(Entry?.EntryNumber?.ToString() ?? "-")</b> | VIN: <b>@Display(Entry?.Vin)</b>
        </RadzenText>

        <RadzenFormField Text="Payment method" Variant="Variant.Outlined" Style="width:100%;">
            <RadzenDropDown TValue="string"
                            Data="@paymentMethodOptions"
                            TextProperty="Label"
                            ValueProperty="Value"
                            @bind-Value="preferredMethod"
                            Style="width:100%;" />
        </RadzenFormField>

        @if (maxPaymentAmount.HasValue)
        {
            <RadzenText TextStyle="TextStyle.Body2">
                <strong>Entry Fee:</strong> @maxPaymentAmount.Value.ToString("C")
            </RadzenText>
        }
        else
        {
            <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-text-secondary-color);">
                The exact amount will be confirmed at checkout.
            </RadzenText>
        }

        <RadzenAlert AlertStyle="AlertStyle.Info" AllowClose="false">
            <RadzenStack Gap="0.25rem">
                <RadzenText><strong>Secure Checkout</strong></RadzenText>
                <RadzenText TextStyle="TextStyle.Body2">
                    You will be redirected to a secure payment page to complete your transaction.
                </RadzenText>
            </RadzenStack>
        </RadzenAlert>

        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem">
            <RadzenButton Text="Cancel" ButtonStyle="ButtonStyle.Light" Click="Cancel" />
            <RadzenButton Text="Continue to Checkout" ButtonStyle="ButtonStyle.Primary" Click="Submit" />
        </RadzenStack>
    }
</RadzenStack>

@code {
    [Parameter]
    public CarShowEntryDto? Entry { get; set; }

    private readonly IReadOnlyList<SelectionOption> paymentMethodOptions =
    [
        new("Cash App Pay", "CashAppPay"),
        new("Venmo", "Venmo"),
        new("Apple Pay", "ApplePay"),
        new("Google Pay", "GooglePay")
    ];

    private string preferredMethod = "CashAppPay";
    private decimal? maxPaymentAmount;
    private bool isLoading = true;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrWhiteSpace(Entry?.PreferredPaymentMethod)
            && paymentMethodOptions.Any(x => string.Equals(x.Value, Entry.PreferredPaymentMethod, StringComparison.OrdinalIgnoreCase)))
        {
            preferredMethod = Entry.PreferredPaymentMethod!;
        }

        try
        {
            if (Entry?.PaidAmount > 0)
            {
                maxPaymentAmount = (decimal)Math.Floor(Entry.PaidAmount.Value);
            }
            else if (Entry?.EntryId is int entryId)
            {
                var paymentInfo = await Client.Api.CarShowEntries[entryId].Payment.GetAsync();
                if (paymentInfo?.PaidAmount > 0)
                {
                    maxPaymentAmount = (decimal)Math.Floor(paymentInfo.PaidAmount.Value);
                }
            }
        }
        catch
        {
            // Amount display is informational only; checkout proceeds without it
        }
        finally
        {
            isLoading = false;
        }
    }

    private void Submit()
    {
        errorMessage = null;

        if (string.IsNullOrWhiteSpace(preferredMethod))
        {
            errorMessage = "Payment method is required.";
            return;
        }

        DialogService.Close(new CarShowEntryPaymentSessionRequestDto
        {
            Amount = null,
            PreferredPaymentMethod = preferredMethod
        });
    }

    private void Cancel()
    {
        DialogService.Close(null);
    }

    private static string Display(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "-" : value;
    }

    private sealed record SelectionOption(string Label, string Value);
}
