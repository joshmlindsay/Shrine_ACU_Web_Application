@page "/fetch-forgot-password"
@rendermode InteractiveServer
@inject AcuCarShowClient Client

<PageTitle>Forgot Password</PageTitle>

<RadzenRow JustifyContent="JustifyContent.Center" class="mt-5">
    <RadzenColumn Size="12" SizeMD="6" SizeLG="4">
        <RadzenCard>
            <RadzenStack Gap="1rem">
                <RadzenText TextStyle="TextStyle.H4">Forgot Password</RadzenText>

                @if (submitted)
                {
                    <RadzenAlert AlertStyle="AlertStyle.Success" AllowClose="false">
                        If an account with that email exists, a password reset link has been sent. Please check your inbox (and spam folder).
                    </RadzenAlert>
                    <RadzenRow JustifyContent="JustifyContent.Center">
                        <RadzenText TextStyle="TextStyle.Body2">
                            <RadzenLink Path="/fetch-login" Text="Back to sign in" />
                        </RadzenText>
                    </RadzenRow>
                }
                else
                {
                    <RadzenText TextStyle="TextStyle.Body2">
                        Enter your username or email address and we will send you a link to reset your password.
                    </RadzenText>

                    <RadzenTemplateForm TItem="ForgotPasswordModel" Data="@form" Submit="HandleSubmitAsync">
                        <RadzenStack Gap="0.75rem">
                            <RadzenFormField Text="Username or Email" Variant="Variant.Outlined" Style="width:100%;">
                                <RadzenTextBox Name="UsernameOrEmail" @bind-Value="form.UsernameOrEmail" Style="width:100%;" />
                            </RadzenFormField>
                            <RadzenRequiredValidator Component="UsernameOrEmail" Text="Username or email is required" Popup="true" />

                            <RadzenButton Text="Send Reset Link"
                                          ButtonType="ButtonType.Submit"
                                          ButtonStyle="ButtonStyle.Primary"
                                          Icon="mail"
                                          Disabled="isBusy"
                                          Style="width:100%;" />
                        </RadzenStack>
                    </RadzenTemplateForm>

                    <RadzenRow JustifyContent="JustifyContent.Center">
                        <RadzenText TextStyle="TextStyle.Body2">
                            <RadzenLink Path="/fetch-login" Text="Back to sign in" />
                        </RadzenText>
                    </RadzenRow>
                }
            </RadzenStack>
        </RadzenCard>
    </RadzenColumn>
</RadzenRow>

@code {
    private ForgotPasswordModel form = new();
    private bool isBusy;
    private bool submitted;

    private async Task HandleSubmitAsync(ForgotPasswordModel _)
    {
        isBusy = true;
        try
        {
            var input = form.UsernameOrEmail?.Trim();
            var isEmail = input?.Contains('@') == true;

            await Client.Api.AppUsers.RequestPasswordReset.PostAsync(new PasswordResetRequestDto
            {
                Email = isEmail ? input : null,
                Username = isEmail ? null : input
            });
        }
        catch
        {
            // Intentionally swallow all errors — always show the same message to prevent account enumeration
        }
        finally
        {
            submitted = true;
            isBusy = false;
        }
    }

    private sealed class ForgotPasswordModel
    {
        public string? UsernameOrEmail { get; set; }
    }
}
