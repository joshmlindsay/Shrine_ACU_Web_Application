@page "/fetch-carshows"
@rendermode InteractiveServer
@inject AcuCarShowClient Client
@inject DialogService DialogService
@inject NavigationManager Navigation
@inject UserSessionService UserSession

<PageTitle>Car Shows</PageTitle>

@if (!UserSession.IsAuthenticated)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning">You must log in before viewing car shows.</RadzenAlert>
}
else if (!UserSession.CanRead)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning">Your account does not have permission to view car shows.</RadzenAlert>
}
else
{
    <RadzenDialog />
    <RadzenStack Gap="1rem">
        <RadzenText TextStyle="TextStyle.H4">Car Show Browser</RadzenText>
        <RadzenText TextStyle="TextStyle.Caption">Acting user: @UserSession.EffectiveDisplayName</RadzenText>

        @if (!string.IsNullOrWhiteSpace(successMessage))
        {
            <RadzenAlert AlertStyle="AlertStyle.Success">@successMessage</RadzenAlert>
        }

        <RadzenRow AlignItems="AlignItems.End" Gap="1rem">
            <RadzenColumn Size="12" SizeMD="6" SizeLG="4">
                <RadzenFormField Text="Select Car Show" Variant="Variant.Outlined" Style="width:100%;">
                    <RadzenDropDown TValue="int?"
                                    Data="@carShows"
                                    TextProperty="Name"
                                    ValueProperty="ShowId"
                                    @bind-Value="selectedShowId"
                                    Change="@OnShowSelectionChanged"
                                    AllowClear="true"
                                    Placeholder="Choose a show"
                                    Style="width:100%;" />
                </RadzenFormField>
            </RadzenColumn>
        </RadzenRow>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <RadzenAlert AlertStyle="AlertStyle.Danger">@errorMessage</RadzenAlert>
        }

        @if (isLoading)
        {
            <RadzenProgressBarCircular Mode="ProgressBarMode.Indeterminate" />
        }

        @if (selectedShow is not null)
        {
            <RadzenCard>
                <RadzenStack Gap="0.5rem">
                    <RadzenText TextStyle="TextStyle.H5">@selectedShow.Name</RadzenText>
                    <RadzenRow>
                        <RadzenColumn Size="12" SizeMD="6"><b>Location:</b> @Display(selectedShow.Location)</RadzenColumn>
                        <RadzenColumn Size="12" SizeMD="6"><b>Category:</b> @Display(selectedShow.Category)</RadzenColumn>
                    </RadzenRow>
                    <RadzenRow>
                        <RadzenColumn Size="12" SizeMD="6"><b>Event Date:</b> @DisplayDate(selectedShow.EventDate)</RadzenColumn>
                        <RadzenColumn Size="12" SizeMD="6"><b>Total Participants:</b> @Display(selectedShow.TotalParticipants)</RadzenColumn>
                    </RadzenRow>
                    <RadzenText><b>Description:</b> @Display(selectedShow.Description)</RadzenText>
                </RadzenStack>
            </RadzenCard>

            <RadzenDataGrid Data="@entries" TItem="CarShowEntryDto" AllowPaging="true" PageSize="10" EmptyText="No cars found for this show.">
                <Columns>
                    <RadzenDataGridColumn TItem="CarShowEntryDto" Property="EntryNumber" Title="#" Width="80px" />
                    <RadzenDataGridColumn TItem="CarShowEntryDto" Property="Vin" Title="VIN" Width="220px" />
                    <RadzenDataGridColumn TItem="CarShowEntryDto" Property="PaymentStatus" Title="Payment" Width="130px" />
                    <RadzenDataGridColumn TItem="CarShowEntryDto" Property="PreferredPaymentMethod" Title="Method" Width="150px" />
                    <RadzenDataGridColumn TItem="CarShowEntryDto" Title="Paid At" Width="140px">
                        <Template Context="entry">@DisplayDate(entry.PaidAtUtc)</Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="CarShowEntryDto" Title="Year">
                        <Template Context="entry">@Display(entry.CarDetail?.Year)</Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="CarShowEntryDto" Title="Make">
                        <Template Context="entry">@Display(entry.CarDetail?.Make)</Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="CarShowEntryDto" Title="Model">
                        <Template Context="entry">@Display(entry.CarDetail?.Model)</Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="CarShowEntryDto" Title="Owner">
                        <Template Context="entry">@Display(entry.CarDetail?.Owner)</Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="CarShowEntryDto" Title="Details" Sortable="false" Filterable="false" Width="110px">
                        <Template Context="entry">
                            <RadzenButton Text="Details" Size="ButtonSize.Small" Click="@(async _ => await OpenDetails(entry))" />
                        </Template>
                    </RadzenDataGridColumn>
                    @if (UserSession.CanManage)
                    {
                        <RadzenDataGridColumn TItem="CarShowEntryDto" Title="Payment Action" Sortable="false" Filterable="false" Width="150px">
                            <Template Context="entry">
                                <RadzenButton Text="Mark Payment" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Primary" Click="@(async _ => await OpenManualPaymentDialogAsync(entry))" Disabled="@(isLoading || !entry.EntryId.HasValue)" />
                            </Template>
                        </RadzenDataGridColumn>
                    }
                </Columns>
            </RadzenDataGrid>
        }
    </RadzenStack>
}

@code {
    private List<CarShowDto> carShows = [];
    private List<CarShowEntryDto> entries = [];
    private CarShowDto? selectedShow;
    private int? selectedShowId;
    private bool isLoading;
    private string? errorMessage;
    private string? successMessage;

    protected override async Task OnInitializedAsync()
    {
        if (!UserSession.IsAuthenticated)
        {
            Navigation.NavigateTo($"/fetch-login?returnUrl={Uri.EscapeDataString("/fetch-carshows")}");
            return;
        }

        if (!UserSession.CanRead)
        {
            Navigation.NavigateTo("/", replace: true);
            return;
        }

        try
        {
            var response = await Client.Api.CarShows.GetAsync();
            carShows = response?.Where(x => x.ShowId.HasValue).ToList() ?? [];
        }
        catch (Exception ex)
        {
            errorMessage = $"Unable to load car shows. {ex.Message}";
        }
    }

    private async Task OnShowSelectionChanged(object? _)
    {
        if (!selectedShowId.HasValue)
        {
            selectedShow = null;
            entries = [];
            return;
        }

        isLoading = true;
        errorMessage = null;

        try
        {
            selectedShow = await Client.Api.CarShows.Details[selectedShowId.Value].GetAsync();
            entries = await LoadEntriesWithCarDetailsAsync(selectedShowId.Value);
        }
        catch (Exception ex)
        {
            selectedShow = null;
            entries = [];
            errorMessage = $"Unable to load show details. {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task<List<CarShowEntryDto>> LoadEntriesWithCarDetailsAsync(int showId)
    {
        var showEntries = (await Client.Api.CarShowEntries.Show[showId].GetAsync())?.ToList() ?? [];

        foreach (var entry in showEntries.Where(x => x.CarDetail is null && !string.IsNullOrWhiteSpace(x.Vin)))
        {
            try
            {
                entry.CarDetail = await Client.Api.CarDetails[entry.Vin!].GetAsync();
            }
            catch
            {
            }
        }

        return showEntries;
    }

    private async Task OpenDetails(CarShowEntryDto entry)
    {
        errorMessage = null;

        if (entry.CarDetail is null && !string.IsNullOrWhiteSpace(entry.Vin))
        {
            try
            {
                entry.CarDetail = await Client.Api.CarDetails[entry.Vin!].GetAsync();
            }
            catch (Exception ex)
            {
                errorMessage = $"Unable to load full details for VIN {entry.Vin}. Showing available data. {ex.Message}";
            }
        }

        var detail = entry.CarDetail ?? new CarDetailDto
        {
            Vin = entry.Vin,
            Status = entry.Status
        };

        await DialogService.OpenAsync<ModalCarDetail>(
            $"{Display(detail.Year)} {Display(detail.Make)} {Display(detail.Model)}",
            new Dictionary<string, object?>
            {
                { nameof(ModalCarDetail.CarDetail), detail }
            },
            new DialogOptions
            {
                Width = "700px",
                CloseDialogOnEsc = true,
                CloseDialogOnOverlayClick = true,
                Resizable = true,
                Draggable = true
            });
    }

    private async Task OpenManualPaymentDialogAsync(CarShowEntryDto entry)
    {
        if (!entry.EntryId.HasValue)
        {
            errorMessage = "Unable to update payment because entry id is missing.";
            return;
        }

        errorMessage = null;
        successMessage = null;

        CarShowEntryPaymentDto? paymentDetails;
        try
        {
            paymentDetails = await Client.Api.CarShowEntries[entry.EntryId.Value].Payment.GetAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Unable to load current payment details for entry #{entry.EntryNumber ?? entry.EntryId}. {ex.Message}";
            return;
        }

        var result = await DialogService.OpenAsync<ManualPaymentDialog>(
            "Manual Payment Update",
            new Dictionary<string, object?>
            {
                { nameof(ManualPaymentDialog.Entry), entry },
                { nameof(ManualPaymentDialog.Payment), paymentDetails }
            },
            new DialogOptions
            {
                Width = "640px",
                CloseDialogOnEsc = true,
                CloseDialogOnOverlayClick = false
            });

        if (result is not CarShowEntryManualPaymentUpdateDto update)
        {
            return;
        }

        try
        {
            var updated = await Client.Api.CarShowEntries[entry.EntryId.Value].Payment.Manual.PutAsync(update);

            if (updated is not null)
            {
                entry.PaymentStatus = updated.PaymentStatus;
                entry.PaymentTiming = updated.PaymentTiming;
                entry.PreferredPaymentMethod = updated.PreferredPaymentMethod;
                entry.PaymentProofReference = updated.PaymentProofReference;
                entry.PaidAmount = updated.PaidAmount;
                entry.PaidAtUtc = updated.PaidAtUtc;
                entry.PaidByUserId = updated.PaidByUserId;
                entry.PaymentProvider = updated.PaymentProvider;
                entry.PaymentProviderSessionId = updated.PaymentProviderSessionId;
                entry.PaymentProviderIntentId = updated.PaymentProviderIntentId;
            }

            successMessage = $"Payment updated for entry #{entry.EntryNumber ?? entry.EntryId}.";
        }
        catch (Exception ex)
        {
            if (IsConcurrencyConflict(ex))
            {
                await RefreshEntryPaymentSnapshotAsync(entry);
                errorMessage = $"Payment update conflict detected for entry #{entry.EntryNumber ?? entry.EntryId}. The record was updated by another user. Latest payment data has been reloaded. Please review and submit again.";
                return;
            }

            errorMessage = $"Unable to update payment for entry #{entry.EntryNumber ?? entry.EntryId}. {ex.Message}";
        }
    }

    private async Task RefreshEntryPaymentSnapshotAsync(CarShowEntryDto entry)
    {
        if (!entry.EntryId.HasValue)
        {
            return;
        }

        try
        {
            var refreshed = await Client.Api.CarShowEntries[entry.EntryId.Value].Payment.GetAsync();
            if (refreshed is null)
            {
                return;
            }

            entry.PaymentStatus = refreshed.PaymentStatus;
            entry.PaymentTiming = refreshed.PaymentTiming;
            entry.PreferredPaymentMethod = refreshed.PreferredPaymentMethod;
            entry.PaymentProofReference = refreshed.PaymentProofReference;
            entry.PaidAmount = refreshed.PaidAmount;
            entry.PaidAtUtc = refreshed.PaidAtUtc;
            entry.PaidByUserId = refreshed.PaidByUserId;
            entry.PaymentProvider = refreshed.PaymentProvider;
            entry.PaymentProviderSessionId = refreshed.PaymentProviderSessionId;
            entry.PaymentProviderIntentId = refreshed.PaymentProviderIntentId;
        }
        catch
        {
        }
    }

    private static bool IsConcurrencyConflict(Exception ex)
    {
        if (string.IsNullOrWhiteSpace(ex.Message))
        {
            return false;
        }

        return ex.Message.Contains("409", StringComparison.OrdinalIgnoreCase)
            || ex.Message.Contains("concurrency", StringComparison.OrdinalIgnoreCase)
            || ex.Message.Contains("rowversion", StringComparison.OrdinalIgnoreCase)
            || ex.Message.Contains("row version", StringComparison.OrdinalIgnoreCase);
    }

    private static string Display(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "-" : value;
    }

    private static string Display(int? value)
    {
        return value?.ToString() ?? "-";
    }

    private static string DisplayDate(DateTimeOffset? value)
    {
        return value?.ToString("MMM dd, yyyy") ?? "-";
    }
}
